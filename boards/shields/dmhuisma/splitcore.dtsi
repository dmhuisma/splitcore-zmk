#include <dt-bindings/zmk/matrix_transform.h>
#include "splitcore_physical_layout.dtsi"

/ {

    chosen {
        zmk,kscan = &kscan0;
        zmk,physical-layout = &physical_layout0;
    };

    kscan0: kscan_composite {
        compatible = "zmk,kscan-composite";
        status = "okay";
        columns = <16>;
        rows = <6>;
    };

    // key matrix
    kscan1: kscan1 {
        compatible = "zmk,kscan-gpio-matrix";
        diode-direction = "col2row";
        wakeup-source;
        status = "disabled";
            
        row-gpios
            = <&gpio0 31    (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            , <&gpio0 29    (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            , <&gpio0 2     (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            , <&gpio1 15    (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            , <&gpio1 7     (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            ;
    };

    default_transform: keymap_transform0 {
        compatible = "zmk,matrix-transform";
        columns = <16>;
        rows = <6>;

        // key matrix, fingers and thumb clusters, rows 0 - 4
        // dpad and RKJXT1F42001 buttons, row 5
        map = <
            RC(0,0) RC(0,1) RC(0,2) RC(0,3) RC(0,4) RC(0,5)                     RC(0,8) RC(0,9) RC(0,10) RC(0,11) RC(0,12) RC(0,13)
            RC(1,0) RC(1,1) RC(1,2) RC(1,3) RC(1,4) RC(1,5)                     RC(1,8) RC(1,9) RC(1,10) RC(1,11) RC(1,12) RC(1,13)
            RC(2,0) RC(2,1) RC(2,2) RC(2,3) RC(2,4) RC(2,5)                     RC(2,8) RC(2,9) RC(2,10) RC(2,11) RC(2,12) RC(2,13)
            RC(3,0) RC(3,1) RC(3,2) RC(3,3) RC(3,4) RC(3,5)                     RC(3,8) RC(3,9) RC(3,10) RC(3,11) RC(3,12) RC(3,13)
                            RC(3,6) RC(3,7)                                                     RC(3,14) RC(3,15)
                                                    RC(4,0) RC(4,1)     RC(4,9)  RC(4,8)
                                            RC(4,6)         RC(4,2)     RC(4,10)          RC(4,14)
                                            RC(4,5) RC(4,4) RC(4,3)     RC(4,11) RC(4,12) RC(4,13)

                                                    RC(5,0)                      RC(5,8)
                                            RC(5,2)         RC(5,3)     RC(5,10)          RC(5,11)
                                                    RC(5,1)                      RC(5,9)
        >;
    };

    // disabled by default - only on right side
    RKJXT1F42001_encoder: encoder_RKJXT1F42001 {
        compatible = "alps,ec11";
        steps = <30>;
        status = "disabled";
    };

    sensors: sensors {
        compatible = "zmk,keymap-sensors";
        sensors = <&RKJXT1F42001_encoder>;

        RKJXT1F42001_encoder {
            triggers-per-rotation = <15>;
        };
    };

    asdc0: split_data_channel {
        compatible = "zmk,arbitrary-split-data-channel";
        channel-id = <1>;
        status = "okay";
    };

    ssr0: split_status_relay {
        compatible = "zmk,split-status-relay";
        asdc-channel = <&asdc0>;
        status = "okay";
    };

    esb_split {
        compatible = "zmk,esb-split";
        // These are arbitrary default addresses. In end user products
        // different addresses should be used for each set of devices.
        base-addr-0 = <0xE5 0x65 0x72 0x92>;
        base-addr-1 = <0xD2 0xB4 0x04 0x98>;
        addr-prefix = <0xB7 0xF4 0xA1 0x54 0x22 0xE1 0xDD 0x11>;
    };
};
